{
  "name": "nest-template",
  "version": "0.0.3",
  "description": "nest",
  "author": "Joye",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "build": "nest build",
    "test:database:sqlite": "ts-node -r tsconfig-paths/register scripts/test-database-sqlite.ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "start": "cross-env NODE_ENV=development nest start",
    "dev": "npm start -- --watch",
    "debug": "npm run dev -- --debug",
    "prod": "node dist/main",
    "pm2:dev": "pm2 start pm2.dev.config.js",
    "pm2:prod": "pm2 start pm2.prod.config.js",
    "pm2:stop": "pm2 stop all",
    "pm2:restart": "pm2 restart all",
    "pm2:delete": "pm2 delete all",
    "pm2:logs": "pm2 logs"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.28",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.28",
    "@nestjs/platform-express": "^11.1.28",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.4.6",
    "axios": "^1.18.1",
    "class-validator": "^0.14.4",
    "class-transformer": "^0.5.1",
    "cookie-parser": "^1.4.7",
    "dayjs": "^1.11.21",
    "lodash": "^4.17.21",
    "mysql2": "^3.23.1",
    "redis": "^5.12.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.24",
    "@nestjs/schematics": "^11.1.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.0",
    "@types/node": "^25.9.5",
    "cross-env": "^10.1.0",
    "detect-libc": "^2.1.2",
    "prettier": "^3.9.6",
    "ts-loader": "^9.6.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  }
}
